{
  "manifest_version": 2,
  "name": "NZBDonkey",
  "homepage_url": "https://tensai75.github.io/NZBDonkey/",
  "description": "The ultimate NZB file downloader extension",
  "default_locale": "en",
  "permissions":[
    "clipboardWrite",
    "contextMenus",
    "activeTab",
    "storage",
    "downloads",
    "notifications",
    "*://*/",
    "cookies",
    "webRequest",
    "webRequestBlocking"
  ],
  "icons":{  
    "16":"/icons/NZBDonkey_16.png",
    "32":"/icons/NZBDonkey_32.png",
    "48":"/icons/NZBDonkey_48.png",
    "96":"/icons/NZBDonkey_96.png",
    "128":"/icons/NZBDonkey_128.png"
  },
  "background": {
    "scripts": [
      "js/background.js"
    ]
  },
  "content_scripts":[  
    {  
        "matches":[  
            "<all_urls>"
        ],
        "js":[  
          "js/content.js"
        ],
        "css":[],
        "run_at":"document_end",
        "all_frames": false
    }
],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "NZBDonkey",
    "default_icon": {
      "16":"/icons/NZBDonkey_16.png",
      "32":"/icons/NZBDonkey_32.png",
      "48":"/icons/NZBDonkey_48.png",
      "96":"/icons/NZBDonkey_96.png",
      "128":"/icons/NZBDonkey_128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    "icons/*",
    "img/*",
    "css/*",
    "mif/*",
    "js/*"
  ]
}
