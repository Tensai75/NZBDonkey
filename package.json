{
  "name": "nzbdonkey",
  "version": "1.0.0-alpha",
  "private": true,
  "scripts": {
    "serve": "set NODE_OPTIONS=--openssl-legacy-provider && vue-cli-service build --mode chrome-dev --watch",
    "serveFF": "set NODE_OPTIONS=--openssl-legacy-provider && vue-cli-service build --mode firefox-dev --watch",
    "test": "set NODE_OPTIONS=--openssl-legacy-provider && vue-cli-service build --mode chrome-dev",
    "testFF": "set NODE_OPTIONS=--openssl-legacy-provider && vue-cli-service build --mode firefox-dev",
    "build": "set NODE_OPTIONS=--openssl-legacy-provider && vue-cli-service build --mode chrome",
    "buildFF": "set NODE_OPTIONS=--openssl-legacy-provider && vue-cli-service build --mode firefox",
    "lint": "set NODE_OPTIONS=--openssl-legacy-provider && vue-cli-service lint"
  },
  "dependencies": {
    "aes-js": "^3.1.2",
    "core-js": "^3.6.5",
    "dexie": "^3.2.3",
    "ezcrypto": "^0.0.3",
    "fast-xml-parser": "^3.19.0",
    "html-entities": "^2.4.0",
    "html-to-formatted-text": "^2.7.0",
    "jsonpath": "^1.1.1",
    "libarchive.js": "^1.3.0",
    "pkcs7": "^1.0.4",
    "promise.any": "^2.0.2",
    "request-promise": "^4.2.6",
    "sanitize-filename": "^1.6.3",
    "text-encoding": "^0.7.0",
    "vee-validate": "^3.4.5",
    "vue": "^2.6.11",
    "vue-router": "^3.2.0",
    "vuedraggable": "^2.24.3",
    "vuex": "^3.4.0"
  },
  "devDependencies": {
    "@vue/cli-plugin-babel": "~4.5.0",
    "@vue/cli-plugin-eslint": "~4.5.0",
    "@vue/cli-plugin-router": "~4.5.0",
    "@vue/cli-plugin-vuex": "~4.5.0",
    "@vue/cli-service": "^4.5.13",
    "@vue/eslint-config-prettier": "^6.0.0",
    "babel-eslint": "^10.1.0",
    "eslint": "^6.7.2",
    "eslint-plugin-prettier": "^3.3.1",
    "eslint-plugin-vue": "^6.2.2",
    "prettier": "^2.2.1",
    "sass": "^1.26.5",
    "sass-loader": "^8.0.2",
    "source-map-loader": "^1.0.0",
    "vue-cli-plugin-browser-extension": "latest",
    "vue-template-compiler": "^2.6.11"
  }
}
